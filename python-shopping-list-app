print("===========SHOPPING LIST APP============")
shopping_list=[]
while True:
    print("1. Add Items")
    print("2. View List  ")
    print("3. Remove Items ")
    print("4. Exit")
    choice=int(input("Enter your choice: "))
    if choice==1:
        item=input("Enter Item Name: ")
        shopping_list.append(item)
        print(f" {item} added to shopping list")
    elif choice==2:
        if len(shopping_list)==0:
            print("No items added to shopping list")
        else:
            print("Your shopping list ")
            index=1
            for item in shopping_list:
                print(str(index) + ". " + item)
                index+=1

    elif choice==3:
         if len(shopping_list)==0:
             print("No items added to shopping list")
         else:
            print("Your shopping list ")
            index=1
            for item in shopping_list:
                print(str(index) + ". " + item)
                index+=1

            item_num=int(input("Enter Item Number: "))
            if item_num >=1 and item_num <=len(shopping_list):
                removed=shopping_list.pop(item_num-1)
                print(f"{removed} removed from shopping list")

            else:
                print("Item not in shopping list")
    elif choice==4:
        print("Thank you for shopping ")

        break
    else:
        print("Invalid choice")

